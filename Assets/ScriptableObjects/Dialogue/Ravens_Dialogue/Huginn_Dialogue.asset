  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ef4120e8d7cc4784ba80e7aeb2d6d58d, type: 3}
  m_Name: Huginn_Dialogue
  m_EditorClassIdentifier: 
  Repeatable: 0
  Lines:
  - Text: You come intent to unleash Ragnarok, Princess of Hel?
    Speaker: {fileID: 11400000, guid: afb70e6f906eb6e458cf847a9948c962, type: 2}
  - Text: I do not know of what you speak. Also, I am not Hel.
    Speaker: {fileID: 11400000, guid: 4f97ef8596ffbe84c8329bcee3fa66b3, type: 2}
  - Text: I see you truly do not comprehend Ragnarok. Prove your body worthy and
      your mind keen in these trials, then you may learn.
    Speaker: {fileID: 11400000, guid: afb70e6f906eb6e458cf847a9948c962, type: 2}
  - Text: Furthermore, you are referred to as Princess of Hel, rather than Queen.
    Speaker: {fileID: 11400000, guid: afb70e6f906eb6e458cf847a9948c962, type: 2}
  - Text: Hm, why set up these trials?
    Speaker: {fileID: 11400000, guid: 4f97ef8596ffbe84c8329bcee3fa66b3, type: 2}
  - Text: Answer my question first; will you free Loki?
    Speaker: {fileID: 11400000, guid: afb70e6f906eb6e458cf847a9948c962, type: 2}
  - Text: He is my father, I refuse to leave him in Aesir chains.
    Speaker: {fileID: 11400000, guid: 4f97ef8596ffbe84c8329bcee3fa66b3, type: 2}
  - Text: Then I must allow you to face the first trial. I see that it is in your
      blood to surround yourself by death, Princess.
    Speaker: {fileID: 11400000, guid: afb70e6f906eb6e458cf847a9948c962, type: 2}
  IsVoiced: 0
  VoiceEventName: 
  VoiceParameterName: 
  OnFinished:
    m_PersistentCalls:
      m_Calls: []
