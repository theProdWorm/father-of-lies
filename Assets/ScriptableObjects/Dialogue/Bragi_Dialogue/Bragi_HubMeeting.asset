  m_Script: {fileID: 11500000, guid: ef4120e8d7cc4784ba80e7aeb2d6d58d, type: 3}
  m_Name: Bragi_HubMeeting
  m_EditorClassIdentifier: 
  Repeatable: 0
  Lines:
  - Text: "You\u2019re Bragi? The one who spoke earlier?"
    Speaker: {fileID: 11400000, guid: 4f97ef8596ffbe84c8329bcee3fa66b3, type: 2}
  - Text: "Indeed I am! The most famed storyteller throughout all the lands, and
      the man who\u2019ll tell your tale, as I mentioned."
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: That you did, but why? What makes me so special? I was just born.
    Speaker: {fileID: 11400000, guid: 4f97ef8596ffbe84c8329bcee3fa66b3, type: 2}
  - Text: 'Is that not what makes you special? Born of the blood of the Father of
      Lies, now set to rescue that poor innocent father who lies chained and tortured
      by the hands of Odin? '
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: Yours is the tale of a being caught between an innocent father and his
      loving wife, and the All-Father himself.
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: Am I supposed to kill the All-Father?!
    Speaker: {fileID: 11400000, guid: 8b9b771dc2f105a40a7ee49c43e5d895, type: 2}
  - Text: By the giants, no! Yet you must prove yourself worthy, so pass through
      the gateways you find in this grove and take on their trials.
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  IsVoiced: 0
  VoiceEventName: 
  VoiceParameterName: 
  OnFinished:
    m_PersistentCalls:
      m_Calls: []
