--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ef4120e8d7cc4784ba80e7aeb2d6d58d, type: 3}
  m_Name: Runestone_StoryOfTheStoryteller
  m_EditorClassIdentifier: 
  Repeatable: 1
  Lines:
  - Text: 'This runestone contains a story. It reads as follows:'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: "One winter deep in a Midgard field,\r\nA nameless warrior bore his shield.\r\nNo
      saga marked his father\u2019s name,\r\nNo skald yet shaped his path to fame."
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: 'The ground was cold, the sky was torn,

      The ravens circled, battle-worn.

      His
      arm grew numb, his breath grew slow,

      His blood ran hot upon the snow.'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: "In Asgard\u2019s height the benches stirred,\r\nSome gods they rose at
      what they heard.\r\nThat lone abandoned mortal cry,\r\nBy anguish alone it
      split the sky."
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: "\u201CCome\u201D said Bragi, voice like lyre,\r\n\u201CTo Valhalla, sit
      by hearth and pyre.\u201D\r\nAnd from the warrior\u2019s mortal chest,\r\nUnfurled
      the story he had long possessed."
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: 'And Bragi listened, still and grave,

      To all the truth, to not gild
      the brave.

      He guards no blade and inflicts no fear,

      For he is
      the god who does not steer.'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  OnFinished:
    m_PersistentCalls:
      m_Calls: []
