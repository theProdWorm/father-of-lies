  m_Script: {fileID: 11500000, guid: ef4120e8d7cc4784ba80e7aeb2d6d58d, type: 3}
  m_Name: Bragi_ThroughFirstDoor
  m_EditorClassIdentifier: 
  Repeatable: 0
  Lines:
  - Text: "And so, the Child of Lies takes their first step towards their father\u2019s
      freedom, braving the unknown horrors in the forest."
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: Horrors? There are more of those monsters here?
    Speaker: {fileID: 11400000, guid: 8b9b771dc2f105a40a7ee49c43e5d895, type: 2}
  - Text: But of course, conflict refines a hero whereas a pleasant stroll does not.
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: That is not what I wanted to know, why are they even here?
    Speaker: {fileID: 11400000, guid: 8b9b771dc2f105a40a7ee49c43e5d895, type: 2}
  - Text: "The hero, worried for her safety, takes her first step towards her father\u2019s
      freedom-"
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: Fine, be that way. I will fight them.
    Speaker: {fileID: 11400000, guid: 8b9b771dc2f105a40a7ee49c43e5d895, type: 2}
  OnFinished:
    m_PersistentCalls:
      m_Calls: []
