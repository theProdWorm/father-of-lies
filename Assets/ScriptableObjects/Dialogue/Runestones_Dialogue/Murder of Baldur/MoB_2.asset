  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ef4120e8d7cc4784ba80e7aeb2d6d58d, type: 3}
  m_Name: MoB_2
  m_EditorClassIdentifier: 
  Repeatable: 1
  Lines:
  - Text: 'This runestone contains the ending of a story. It reads as follows:'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: 'Then Baldur dreamed of dying; bright Baldur, beloved of all.

      So
      fair all things forget their thirst for blood.

      The bright god fell,
      and all of Asgard looked on in appall.

      And the Father of Lies laughed
      right where he stood

'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: 'Was it hatred for the shining, envy of the adored?

      Was it grief
      that curdled inward, made venom of his love?

      For every cheer that hailed
      Baldur rang like striking from a sword.

      On the chains that bit his children,
      far below, far above.'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: Such it is that trickster gods love, and lovely gods trick.
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  OnFinished:
    m_PersistentCalls:
      m_Calls: []
