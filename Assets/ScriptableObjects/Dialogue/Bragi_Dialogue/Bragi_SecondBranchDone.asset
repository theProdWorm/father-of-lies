  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ef4120e8d7cc4784ba80e7aeb2d6d58d, type: 3}
  m_Name: Bragi_SecondBranchDone
  m_EditorClassIdentifier: 
  Repeatable: 0
  Lines:
  - Text: Welcome back, child of lies.
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: You seem disturbed.
    Speaker: {fileID: 11400000, guid: 4f97ef8596ffbe84c8329bcee3fa66b3, type: 2}
  - Text: "Forgive me. If your tale reaches its final page as you\u2019re trying
      to do, Ragnarok will indeed awaken. "
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: I shall not condemn the world for such a perfect ending. Turn back now
      and let the prophecy remain unfulfilled.
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  - Text: What, no, no no no! I have come so close, I cannot stop now? Why else would
      you let me come this far?
    Speaker: {fileID: 11400000, guid: 8b9b771dc2f105a40a7ee49c43e5d895, type: 2}
  - Text: I wish to see your tale to its finish, but it is not to be this one, no
      matter how much we want it. You can yet live a life.
    Speaker: {fileID: 11400000, guid: 221624e13721edf47a3982f9e2ec5bd5, type: 2}
  IsVoiced: 0
  VoiceEventName: 
  VoiceParameterName: 
  OnFinished:
    m_PersistentCalls:
      m_Calls: []
