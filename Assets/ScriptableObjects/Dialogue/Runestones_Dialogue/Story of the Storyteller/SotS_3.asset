  m_Script: {fileID: 11500000, guid: ef4120e8d7cc4784ba80e7aeb2d6d58d, type: 3}
  m_Name: SotS_3
  m_EditorClassIdentifier: 
  Repeatable: 1
  Lines:
  - Text: 'This runestone contains the ending of a story. It reads as follows:'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: "\u201CCome\u201D said Bragi, voice like lyre,\r\n\u201CTo Valhalla, sit
      by hearth and pyre.\u201D\r\nAnd from the warrior\u2019s mortal chest,\r\nUnfurled
      the story he had long possessed."
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  - Text: 'And Bragi listened, still and grave,

      To all the truth, to not
      gild the brave.

      He guards no blade and inflicts no fear,

      For
      he is the god who does not steer.'
    Speaker: {fileID: 11400000, guid: 6386bee0cce89a84f80df160c871f056, type: 2}
  OnFinished:
    m_PersistentCalls:
      m_Calls: []
